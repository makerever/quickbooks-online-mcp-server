# ============================================================
# HTTP server (Railway sets PORT automatically; default 3000 locally)
# ============================================================
PORT=3000

# ============================================================
# QuickBooks app identity (OPTIONAL)
# Used only as the consumerKey/consumerSecret on the node-quickbooks
# constructor. Token acquisition is BYO — each MCP caller passes their
# own QBO access token in the Authorization bearer — so these are not
# strictly required unless your Intuit app expects them to be present.
# ============================================================
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
